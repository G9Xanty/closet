# ── Backend (Express / Vercel Serverless) ──────────────
NODE_ENV=development
PORT=3000

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin credentials (created on first init)
ADMIN_EMAIL=admin@closet.local
ADMIN_PASSWORD=your-strong-admin-password

# ── Frontend (Vite — must be prefixed with VITE_) ────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_PUBLIC_URL=https://your-app.vercel.app

# ── Vercel Environments ───────────────────────────────
# Configure these in Vercel Dashboard → Project → Settings → Environment Variables
#
# Production:
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
#   ADMIN_EMAIL, ADMIN_PASSWORD
#   VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY
#
# Preview (auto-generated from PR branches):
#   Same variables — use the same Supabase project or a separate preview project
#
# Development (local):
#   Copy this file as .env and fill values

# ── Notas ──────────────────────────────────────────────
# - Las variables VITE_* se exponen al frontend. No pongas SERVICE_ROLE_KEY ahí.
# - SERVICE_ROLE_KEY solo la necesita el backend (server.cjs / api/index.js).
# - En Vercel, las variables de entorno se leen sin dotenv (nativas del runtime).
